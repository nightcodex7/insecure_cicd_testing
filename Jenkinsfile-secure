pipeline {
    agent any

    environment {
        DB_PASSWORD = credentials('db-password-id')
        IMAGE_NAME  = 'nginx:latest'   // simulate third-party image
    }

    stages {

        stage('Pull Image (Untrusted Source)') {
            steps {
                sh 'docker pull $IMAGE_NAME'
            }
        }

        stage('Scan Image (Trivy Gate)') {
            steps {
                // Fail the build if CRITICAL vulns are found
                sh '''
                trivy image \
                  --severity CRITICAL \
                  --exit-code 1 \
                  --no-progress \
                  $IMAGE_NAME
                '''
            }
        }

        stage('Run Image (Only if Scan Passes)') {
            steps {
                sh '''
                docker run -d -p 8080:80 $IMAGE_NAME
                '''
            }
        }
    }
}