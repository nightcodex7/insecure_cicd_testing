pipeline {
    agent any

    environment {
        DB_PASSWORD = credentials('db-password-id')
        IMAGE_NAME  = 'nginx:latest'   // simulate third-party image
    }

    stages {

        stage('Cleanup Old Containers') {
            steps {
                sh 'docker rm -f nginx-demo || true'
            }
        }

        stage('Docker Login (Required for Scout)') {
            steps {
                sh 'docker login -u $DOCKER_USER -p $DOCKER_PASS || true'
            }
        }

        stage('Pull Image (Untrusted Source)') {
            steps {
                sh 'docker pull $IMAGE_NAME'
            }
        }

        stage('Scan Image (Docker Scout)') {
            steps {
                sh '''
                docker scout cves $IMAGE_NAME \
                --only-severity critical \
                --exit-code 1
                '''
            }
        }

        stage('Run Image (Only if Scan Passes)') {
            steps {
                sh '''
                docker run -d \
                -p 8081:80 \
                --name nginx-demo \
                $IMAGE_NAME
                '''
            }
        }
    }
}